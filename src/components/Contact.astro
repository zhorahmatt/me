---
import type { Locale } from "../i18n/utils";
import { t } from "../i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section class="py-12 md:py-20">
  <h1 class="font-serif text-hero mb-4 reveal">
    {locale === 'en' ? 'Get in Touch.' : 'Hubungi Saya.'}
  </h1>
  <p class="text-ink-secondary text-lg sm:text-[19px] max-w-[768px] mb-10 reveal reveal-delay-1">
    {t("contact.subtitle", locale)}
  </p>

  <div class="grid md:grid-cols-[1fr_300px] gap-12">
    <!-- Contact Form -->
    <form class="space-y-5 reveal reveal-delay-2" method="POST" action="#">
      <div>
        <label for="name" class="block text-sm font-medium text-ink mb-2">
          {locale === 'en' ? 'Name' : 'Nama'}
        </label>
        <input
          type="text"
          id="name"
          name="name"
          class="form-input"
          placeholder={locale === 'en' ? 'Your name' : 'Nama Anda'}
          required
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-ink mb-2">
          Email
        </label>
        <input
          type="email"
          id="email"
          name="email"
          class="form-input"
          placeholder={locale === 'en' ? 'your@email.com' : 'email@anda.com'}
          required
        />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-ink mb-2">
          {locale === 'en' ? 'Message' : 'Pesan'}
        </label>
        <textarea
          id="message"
          name="message"
          rows="5"
          class="form-input resize-none"
          placeholder={locale === 'en' ? 'Tell me about your project...' : 'Ceritakan tentang proyek Anda...'}
          required
        ></textarea>
      </div>
      <button type="submit" class="btn-primary">
        {locale === 'en' ? 'Send Message' : 'Kirim Pesan'}
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </form>

    <!-- Sidebar: Schedule a call + social -->
    <div class="space-y-8 reveal reveal-delay-3">
      <!-- Schedule call -->
      <div class="card p-6">
        <h3 class="font-serif text-xl mb-2">
          {locale === 'en' ? 'Prefer a call?' : 'Lebih suka telepon?'}
        </h3>
        <p class="text-sm text-ink-secondary mb-4">
          {locale === 'en' ? 'Book a 30-min intro call to discuss your project.' : 'Jadwalkan panggilan 30 menit untuk membahas proyek Anda.'}
        </p>
        <a href="#" class="link-underline text-sm font-medium text-ink">
          {locale === 'en' ? 'Schedule a call ↗' : 'Jadwalkan panggilan ↗'}
        </a>
      </div>

      <!-- Social links -->
      <div>
        <h3 class="font-serif text-xl mb-4">
          {locale === 'en' ? 'Find me online' : 'Temukan saya online'}
        </h3>
        <div class="space-y-3">
          <a href="mailto:hello@rahmathidayat.my.id" class="flex items-center gap-3 text-sm text-ink-secondary hover:text-ink group">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
            <span>hello@rahmathidayat.my.id</span>
          </a>
          <a href="https://github.com/rahmathidayat" target="_blank" rel="noopener" class="flex items-center gap-3 text-sm text-ink-secondary hover:text-ink group">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            <span>GitHub</span>
          </a>
          <a href="https://linkedin.com/in/rahmathidayat" target="_blank" rel="noopener" class="flex items-center gap-3 text-sm text-ink-secondary hover:text-ink group">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            <span>LinkedIn</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
