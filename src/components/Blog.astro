---
import type { Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const posts = [
  {
    title: locale === 'en' ? 'Building Performance Trees with Vue.js' : 'Membangun Pohon Kinerja dengan Vue.js',
    excerpt: locale === 'en'
      ? 'How I built an interactive tree visualization for government performance data.'
      : 'Bagaimana saya membangun visualisasi tree interaktif untuk data kinerja pemerintah.',
    date: '2024-02-15',
    category: 'Engineering',
  },
  {
    title: locale === 'en' ? 'Scaling Laravel for 30+ SKPD Reports' : 'Scaling Laravel untuk 30+ Laporan SKPD',
    excerpt: locale === 'en'
      ? 'Lessons learned from building an automated report generation system.'
      : 'Pelajaran dari membangun sistem pembuatan laporan otomatis.',
    date: '2024-01-20',
    category: 'Backend',
  },
  {
    title: locale === 'en' ? 'From CRA to Astro: A Migration Story' : 'Dari CRA ke Astro: Cerita Migrasi',
    excerpt: locale === 'en'
      ? 'Why I chose Astro for my personal site and the migration process.'
      : 'Mengapa saya memilih Astro untuk situs pribadi dan proses migrasinya.',
    date: '2023-12-10',
    category: 'Frontend',
  },
];

function formatDate(dateStr: string, loc: string) {
  return new Date(dateStr).toLocaleDateString(loc === 'id' ? 'id-ID' : 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<section class="py-12 md:py-20">
  <h1 class="font-serif text-hero mb-4 reveal">Blog.</h1>
  <p class="text-ink-secondary text-lg sm:text-[19px] max-w-[768px] mb-12 reveal reveal-delay-1">
    {locale === 'en'
      ? 'Thoughts on engineering, architecture, and building things that last.'
      : 'Pemikiran tentang engineering, arsitektur, dan membangun hal yang bertahan lama.'
    }
  </p>

  <div class="space-y-6">
    {posts.map((post, i) => (
      <a href="#" class={`block card p-6 group reveal reveal-delay-${i + 1}`}>
        <div class="flex items-center gap-3 mb-2">
          <span class="text-xs font-mono text-ink-muted uppercase tracking-wider">{post.category}</span>
          <span class="text-xs text-ink-light">·</span>
          <span class="text-xs text-ink-muted">{formatDate(post.date, locale)}</span>
        </div>
        <h2 class="font-serif text-xl md:text-2xl text-ink mb-2 group-hover:text-accent transition-colors">
          {post.title}
        </h2>
        <p class="text-base text-ink-secondary leading-relaxed">{post.excerpt}</p>
      </a>
    ))}
  </div>
</section>
