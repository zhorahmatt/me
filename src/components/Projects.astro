---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const projects = [
  {
    name: 'E-Kinerja',
    category: locale === 'en' ? 'Government Platform' : 'Platform Pemerintah',
    year: '2023',
    description: locale === 'en'
      ? 'Government performance management and monitoring system with real-time dashboards and reporting.'
      : 'Sistem manajemen dan monitoring kinerja pemerintah dengan dashboard real-time dan pelaporan.',
    link: '#',
  },
  {
    name: 'Pohon Kinerja',
    category: locale === 'en' ? 'Data Visualization' : 'Visualisasi Data',
    year: '2023',
    description: locale === 'en'
      ? 'Interactive performance tree visualization with PDF/PNG export capabilities.'
      : 'Visualisasi pohon kinerja interaktif dengan kemampuan ekspor PDF/PNG.',
    link: '#',
  },
  {
    name: 'Renstra Module',
    category: locale === 'en' ? 'Enterprise Tool' : 'Alat Enterprise',
    year: '2022',
    description: locale === 'en'
      ? 'Strategic planning module with cascading filters and multi-level organizational views.'
      : 'Modul perencanaan strategis dengan filter berjenjang dan tampilan organisasi multi-level.',
    link: '#',
  },
  {
    name: 'Report Generator',
    category: locale === 'en' ? 'Automation' : 'Automasi',
    year: '2023',
    description: locale === 'en'
      ? 'Automated batch PDF export system for 30+ government department reports.'
      : 'Sistem ekspor PDF batch otomatis untuk 30+ laporan departemen pemerintah.',
    link: '#',
  },
];
---

<section class="py-12 md:py-20">
  <h1 class="font-serif text-hero mb-4 reveal">
    {locale === 'en' ? 'Work.' : 'Karya.'}
  </h1>
  <p class="text-ink-secondary text-lg sm:text-[19px] max-w-[768px] mb-12 reveal reveal-delay-1">
    {t('projects.subtitle', locale)}
  </p>

  <!-- Project cards -->
  <div class="space-y-8">
    {projects.map((project, i) => (
      <a
        href={project.link}
        class={`block card p-6 md:p-8 group reveal reveal-delay-${(i % 4) + 1}`}
      >
        <div class="flex items-center gap-3 mb-3">
          <span class="text-xs font-mono text-ink-muted uppercase tracking-wider">{project.category}</span>
          <span class="text-xs text-ink-light">·</span>
          <span class="text-xs font-mono text-ink-muted">{project.year}</span>
        </div>
        <h2 class="font-serif text-2xl md:text-3xl text-ink mb-3 group-hover:text-accent transition-colors">
          {project.name}
        </h2>
        <p class="text-ink-secondary text-base leading-relaxed max-w-[600px]">
          {project.description}
        </p>
        <div class="mt-4 flex items-center gap-2 text-sm text-ink-muted group-hover:text-ink transition-colors">
          <span>{locale === 'en' ? 'View project' : 'Lihat proyek'}</span>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="7" y1="17" x2="17" y2="7"/>
            <polyline points="7 7 17 7 17 17"/>
          </svg>
        </div>
      </a>
    ))}
  </div>
</section>
