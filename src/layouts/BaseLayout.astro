---
import type { Locale } from "../i18n/utils";
import { t, getAlternateLocale, localePath } from "../i18n/utils";

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  activePage?: string;
}

const { locale, title = "Rahmat Hidayat", description = "", activePage = "home" } = Astro.props;
const altLocale = getAlternateLocale(locale);

const navItems = [
  { id: "home", href: localePath("/", locale), icon: "home", label: "Home" },
  { id: "about", href: localePath("/about", locale), icon: "heart", label: t("nav.about", locale) },
  { id: "work", href: localePath("/work", locale), icon: "cog", label: t("nav.projects", locale) },
  { id: "blog", href: localePath("/blog", locale), icon: "bell", label: "Blog" },
  { id: "contact", href: localePath("/contact", locale), icon: "phone", label: t("nav.contact", locale) },
];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description || t("hero.intro", locale)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body class="min-h-screen bg-paper text-ink font-sans antialiased selection:bg-ink selection:text-paper overscroll-none">
    
    <!-- Floating Island Navigation -->
    <div class="fixed top-4 left-1/2 -translate-x-1/2 md:top-1/2 md:left-20 md:-translate-y-1/2 md:translate-x-0 z-50 flex flex-row md:flex-col items-center gap-1.5 md:gap-2 px-2 py-2 md:px-2 md:py-3 bg-paper/80 backdrop-blur-md border border-border/60 shadow-[0_4px_12px_rgba(0,0,0,0.05)] rounded-full transition-all">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "group relative flex items-center justify-center w-12 h-12 rounded-full text-ink-muted hover:text-ink hover:bg-black/5 transition-colors",
            { "bg-black/5 text-ink": activePage === item.id }
          ]}
          aria-label={item.label}
        >
          {item.icon === "home" && (
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          )}
          {item.icon === "heart" && (
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
          )}
          {item.icon === "cog" && (
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
          )}
          {item.icon === "bell" && (
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20l-6.5-4L7 22V7a5 5 0 015-5h1.5"/></svg>
          )}
          {item.icon === "phone" && (
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          )}
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-ink text-paper text-sm font-medium rounded-md opacity-0 pointer-events-none -translate-x-2 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-200 whitespace-nowrap shadow-[0_4px_12px_rgba(0,0,0,0.1)] hidden md:block">
            {item.label}
          </span>
        </a>
      ))}
      <div class="w-[1px] h-8 md:w-8 md:h-[1px] bg-border/80 mx-1 md:mx-0 md:my-1"></div>
      <a 
        href={localePath("/", altLocale)} 
        class="group relative flex items-center justify-center w-12 h-12 rounded-full text-ink-muted hover:text-ink hover:bg-black/5 transition-colors font-mono text-[13px] font-bold tracking-wider" 
        aria-label={`Switch to ${altLocale.toUpperCase()}`}
      >
        {altLocale.toUpperCase()}
        <span class="absolute left-full ml-4 px-3 py-1.5 bg-ink text-paper font-sans text-sm font-medium rounded-md opacity-0 pointer-events-none -translate-x-2 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-200 whitespace-nowrap shadow-[0_4px_12px_rgba(0,0,0,0.1)] hidden md:block tracking-normal">
          Switch to {altLocale.toUpperCase()}
        </span>
      </a>
      <!-- Theme toggle placeholder (Sun/Moon) -->
      <button class="group relative flex items-center justify-center w-12 h-12 rounded-full text-ink-muted hover:text-ink hover:bg-black/5 transition-colors" aria-label="Toggle Theme">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <span class="absolute left-full ml-4 px-3 py-1.5 bg-ink text-paper text-sm font-medium rounded-md opacity-0 pointer-events-none -translate-x-2 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-200 whitespace-nowrap shadow-[0_4px_12px_rgba(0,0,0,0.1)] hidden md:block">
          Toggle Theme
        </span>
      </button>
    </div>

    <!-- Main content -->
    <main class="page-wrapper pt-28 md:pt-20">
      <div class="page-content">
        <slot />
      </div>
    </main>

    <!-- Footer -->
    <footer class="page-wrapper mt-20">
      <div class="page-content border-t border-border py-8">
        <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-ink-muted">
          <span>© 2026 Rahmat Hidayat</span>
          <div class="flex gap-5">
            <a href="https://github.com/rahmathidayat" target="_blank" rel="noopener" class="hover:text-ink transition-colors">GitHub</a>
            <a href="https://linkedin.com/in/rahmathidayat" target="_blank" rel="noopener" class="hover:text-ink transition-colors">LinkedIn</a>
            <a href="mailto:hello@rahmathidayat.my.id" class="hover:text-ink transition-colors">Email</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // Scroll reveal
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("visible");
            }
          });
        },
        { threshold: 0.1 },
      );
      document
        .querySelectorAll(".reveal")
        .forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
